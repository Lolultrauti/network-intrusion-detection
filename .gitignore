# --- Dataset (large; download separately, see README) ---
# keep the small example stream file (data/stream.csv) but ignore the rest
data/*
!data/stream.csv
*.arff
*.jpg
*.png.bak

# --- Generated plots (regenerated by train_model.py) ---
plots/

# --- Runtime logs (prediction log is generated locally) ---
logs/

# Keep artifacts/ committed so the Streamlit app runs without retraining,
# but ignore the optional neural-net test/scratch files.
artifacts/_*.pkl
artifacts/label_encoder.pkl

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
